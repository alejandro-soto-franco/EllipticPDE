# Lean
/lean/.lake
/lean/.lake/

# Rust
/numerics/rust/target
/numerics/rust/target/
Cargo.lock

# Python
.venv/
__pycache__/
*.pyc

# LaTeX build artefacts
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.run.xml
*.synctex.gz
*.xdv
*.toc
*.out
*.log
*.pdf
# but keep the committed manuscript figures (generated by numerics/python/figures.py)
!/latex/manuscript/figures/*.pdf

# Stray Meridian export tempfiles (lean-sync writes these into the project)
/lean/meridian-dump-*.ttl

# tstex tool scratch (writes into the project root)
/tstex_modules/

# Adduce local workspace state (the citation library is global at ~/.adduce;
# cite drift/status auto-discover this project without it). Render-layout dirs too.
# The signed formalization drift lock IS version-controlled: it records the
# human sign-off that `adduce formalize check` verifies against.
/latex/.adduce/*
!/latex/.adduce/formalization.lock.toml
/latex/manuscript/latex/
/latex/manuscript/summaries/
/latex/manuscript/literature/

# committed manuscript label snapshot read by the litreview via xr-hyper
!/latex/litreview/manuscript.aux
