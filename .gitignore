# but keep the committed manuscript figures (generated by numerics/python/figures.py)
!/latex/figures/*.pdf

# Stray Meridian export tempfiles (lean-sync writes these into the project)
/lean/meridian-dump-*.ttl

# Stratum local workspace state (the citation library is global at ~/.stratum;
# cite drift/status auto-discover this project without it). Render-layout dirs too.
# The signed formalization drift lock IS version-controlled: it records the
# human sign-off that `stratum formalize check` verifies against.
/latex/.stratum/*
!/latex/.stratum/formalization.lock.toml
/latex/latex/
/latex/summaries/
/latex/literature/
